{
  "manifest_version": 3,
  "name": "Willow Wish Price Watcher",
  "version": "0.1.0",
  "description": "Refreshes prices for your Willow Wish wishlist items on sites the server can't reach directly (Nykaa, Meesho, Instamart).",
  "permissions": ["storage", "alarms", "scripting", "tabs"],
  "host_permissions": [
    "https://*.nykaa.com/*",
    "https://*.meesho.com/*",
    "https://*.swiggy.com/*",
    "https://kjbeotlksumouwedpvfz.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Willow Wish Price Watcher"
  },
  "web_accessible_resources": [
    {
      "resources": ["content-extract.js"],
      "matches": [
        "https://*.nykaa.com/*",
        "https://*.meesho.com/*",
        "https://*.swiggy.com/*"
      ]
    }
  ]
}
